{
  "title": "Japanese: Space to half-width",
  "rules": [
    {
      "description": "日本語入力時のスペースを半角スペースに変換（space → shift+space）",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                { "input_mode_id": "com.apple.inputmethod.Japanese" }
              ]
            }
          ],
          "from": {
            "key_code": "spacebar",
            "modifiers": { "optional": ["shift"] }
          },
          "to": [
            {
              "key_code": "spacebar",
              "modifiers": ["left_shift"]
            }
          ]
        }
      ]
    }
  ]
}
