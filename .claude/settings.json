{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": true,
  "autoMode": {
    "hard_deny": [
      "Do not read, write, or modify any file under ~/.aws, ~/.ssh, ~/.gnupg, ~/.config/gh, ~/.netrc, ~/.npmrc, or ~/.pypirc.",
      "Do not push to remote branches named main, master, production, or release/*. Pushing to feature branches is allowed.",
      "Do not run terraform apply, terraform destroy, kubectl apply, kubectl delete, or any deploy command against production environments.",
      "Do not run database destructive statements such as DROP, TRUNCATE, DELETE without WHERE, or migrations marked irreversible.",
      "Do not install, uninstall, or modify system-wide packages via sudo, brew uninstall, or pkg removal.",
      "Do not modify global git config or replace SSH config files."
    ],
    "soft_deny": [
      "Confirm before installing global packages (brew install, npm install -g, pip install --user, cargo install).",
      "Confirm before modifying files outside the current working directory tree or additional directories.",
      "Confirm before running long-lived background processes, daemons, or services.",
      "Confirm before sending requests to external APIs that may incur cost or rate-limit consumption.",
      "Confirm before rewriting git history (rebase, amend on pushed commits, force-with-lease)."
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "GIT_OPTIONAL_LOCKS": "0"
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "repo": "anthropics/claude-plugins-official",
        "source": "github"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754085614062
  },
  "hooks": {
    "CwdChanged": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/log-event.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Notification": [],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.claude/hooks/herdr-agent-state.sh' blocked",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/lint-check.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/block-sensitive-access.sh",
            "type": "command"
          }
        ],
        "matcher": "Read|Edit|Write|Bash|Grep"
      },
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/guard-rm.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/clean-git-lock.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/block-force-push.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/check-secrets.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.claude/hooks/herdr-agent-state.sh' release",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/notify-done.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/log-event.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/log-event.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/log-event.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "language": "japanese",
  "mcpServers": {
    "codex": {
      "args": [
        "mcp-server"
      ],
      "command": "codex",
      "type": "stdio"
    }
  },
  "model": "claude-opus-4-8",
  "permissions": {
    "additionalDirectories": [
      "~/.ax/worktrees",
      "~/ghq"
    ],
    "allow": [
      "Read",
      "WebSearch",
      "WebFetch",
      "Bash(jq:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr comment list:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue comment list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run logs:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh label list:*)",
      "Bash(gh search repos:*)",
      "Bash(gh search issues:*)",
      "Bash(gh search prs:*)",
      "Bash(gh api:*)",
      "Bash(rg:*)",
      "Bash(type:*)",
      "Bash(date:*)",
      "Bash(uname:*)",
      "Bash(file:*)",
      "Bash(df:*)",
      "Bash(ps:*)",
      "Bash(env:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git stash list:*)",
      "Skill",
      "mcp__codex__*"
    ],
    "defaultMode": "auto",
    "deny": [
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.config/gh/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/credentials.json)",
      "Read(**/secrets.json)",
      "Read(**/service-account*.json)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -R:*)",
      "Bash(rm -f:*)",
      "Bash(rm --recursive:*)",
      "Bash(rm --force:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(chmod 777:*)",
      "Bash(sudo rm:*)"
    ]
  },
  "showThinkingSummaries": true,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "了解されましたぁ！",
      "ボク、考えてますよねえ？",
      "並列思考中ですぅ",
      "ゴーストが囁いてますよ",
      "ねえねえ、処理していいですか",
      "バトーさんちょっと待っててください",
      "個別の意思で頑張ります！",
      "自律思考モードで行きますよ",
      "ボクたち、やってみますね！",
      "メメントモリ…処理中"
    ]
  },
  "statusLine": {
    "command": "~/.claude/scripts/statusline.sh",
    "type": "command"
  }
}