{
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "bash ~/.codex/hooks/notify-permission.sh",
            "statusMessage": "Sending permission notification",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.codex/herdr-agent-state.sh' blocked",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash ~/.codex/hooks/lint-check.sh",
            "statusMessage": "Running shellcheck",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|apply_patch"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash ~/.codex/hooks/guard-rm.sh",
            "statusMessage": "Checking rm command",
            "type": "command"
          },
          {
            "command": "bash ~/.codex/hooks/block-force-push.sh",
            "statusMessage": "Checking git push command",
            "type": "command"
          },
          {
            "command": "bash ~/.codex/hooks/clean-git-lock.sh",
            "statusMessage": "Checking git lock",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.codex/hooks/block-sensitive-access.sh",
            "statusMessage": "Checking sensitive paths",
            "type": "command"
          }
        ],
        "matcher": "Bash|Edit|Write|apply_patch"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.codex/hooks/check-secrets.sh",
            "statusMessage": "Checking patch for secrets",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|apply_patch"
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.codex/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.codex/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash ~/.codex/hooks/notify-done.sh",
            "statusMessage": "Sending completion notification",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.codex/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash '/Users/thirai/.codex/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}